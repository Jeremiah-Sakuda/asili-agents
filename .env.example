# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=asili-agents-hackathon
GOOGLE_CLOUD_LOCATION=us-central1

# Google Gemini API Key (for local development without Vertex AI)
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OR use GCP Service Account (for Vertex AI authentication)
# This can point to the main Asili project's service account
GOOGLE_APPLICATION_CREDENTIALS=

# Vertex AI Search (for catalog grounding)
VERTEX_SEARCH_DATASTORE_ID=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Database (PostgreSQL for production, SQLite for local dev)
DATABASE_URL=sqlite+aiosqlite:///./asili_agents.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080

# Logging
LOG_LEVEL=INFO

# Demo Mode (uses mock data instead of live services)
DEMO_MODE=true
