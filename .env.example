# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=asili-agents-hackathon
GOOGLE_CLOUD_LOCATION=us-central1

# Google Gemini API Key (for local development without Vertex AI)
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OR use GCP Service Account (for Vertex AI authentication)
# This can point to the main Asili project's service account
GOOGLE_APPLICATION_CREDENTIALS=

# MongoDB Atlas — the system of record + the agents' grounding source.
# When MONGODB_URI is set, the API reads catalog/policy from Atlas and (with
# USE_MCP=true) the agents read it through the MongoDB MCP server.
MONGODB_URI=
MONGODB_DATABASE=asili

# MongoDB MCP grounding
# USE_MCP=true routes the agents' catalog reads through `npx mongodb-mcp-server`.
USE_MCP=false
MCP_READ_ONLY=true

# Telegram channel — kept as a dev/secondary channel (sellers live on IG/WhatsApp).
# It is the one channel that can drive inbound -> draft -> approve -> real send
# end-to-end without Meta credentials. Get a token from @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Public URL of this service (used by scripts/set_telegram_webhook.py).
PUBLIC_BASE_URL=

# ── Channel connectors: Instagram + WhatsApp (Meta) ──────────────────────────
# One Asili app, multi-tenant: each seller connects their OWN IG/WhatsApp account.
# Customers message the seller's handle; Asili replies AS the seller, only after
# the seller approves. No shared bot, no agent auto-send. All per-seller tokens
# are encrypted at rest (TOKEN_ENCRYPTION_KEY) and never logged.

# Meta App (Instagram-Login path; no linked Facebook Page needed).
META_APP_ID=
META_APP_SECRET=
# OAuth redirect registered in the Meta App dashboard. Points at this service:
#   https://<this-service>/api/instagram/oauth/callback
INSTAGRAM_REDIRECT_URI=
# Token you choose; echoed back on the GET webhook verification handshake (used
# for both /api/instagram/webhook and /api/whatsapp/webhook).
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# AES-256-GCM master key for per-seller channel tokens. Generate with:
#   python -c "from asili_agents.integrations.secrets import TokenVault; print(TokenVault.generate_key_b64())"
TOKEN_ENCRYPTION_KEY=
# HMAC secret that signs the OAuth `state`, binding a connect flow to a seller_id.
OAUTH_STATE_SECRET=
# Public base URL of the marketing/app site, for the post-OAuth redirect back to
# onboarding, e.g. https://tryasili.com
PUBLIC_APP_BASE_URL=

# WhatsApp Cloud API via a BSP. The connector is built behind the seam but inert
# until a BSP account + creds are wired; flip to true once they are.
WHATSAPP_BSP_LIVE=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080

# Logging
LOG_LEVEL=INFO

# Demo Mode (in-process seed data; set false when MONGODB_URI is configured)
DEMO_MODE=true
